@model IEnumerable<TravelBookingWeb.Models.Hotel>

@{
    // Verificăm dacă utilizatorul curent este Admin
    bool esteAdmin = User.IsInRole("Admin");
    ViewData["Title"] = esteAdmin ? "Gestionare Hoteluri" : "Destinații Populare";
}

@section Styles {
    <style>
        /* Container principal */
        .results-page-container {
            display: flex;
            gap: 25px;
            padding: 30px;
            background-color: #f4f7f6;
            min-height: 100vh;
        }

        /* Cardul de Hotel - Format Orizontal */
        .hotel-card {
            display: flex;
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 25px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            border: 1px solid #e0e0e0;
            min-height: 280px;
        }

        /* PARTEA STÂNGĂ: Caseta Albastră cu Nume */
        .hotel-visual-box {
            width: 320px;
            background: linear-gradient(135deg, #007bff, #0056b3);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
            padding: 20px;
            flex-shrink: 0;
            position: relative;
        }

            .hotel-visual-box h3 {
                font-weight: 800;
                font-size: 1.6rem;
                margin-bottom: 10px;
                text-shadow: 1px 1px 4px rgba(0,0,0,0.2);
            }

            .hotel-visual-box .location-label {
                font-size: 1.1rem;
                opacity: 0.9;
                display: flex;
                align-items: center;
                gap: 5px;
            }

        /* PARTEA DREAPTĂ: Detalii */
        .hotel-details-box {
            padding: 25px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .hotel-title-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .score-badge-container {
            text-align: center;
        }

        .score-badge {
            background-color: #003580;
            color: white;
            padding: 5px 12px;
            border-radius: 6px;
            font-weight: bold;
            font-size: 1.1rem;
            display: block;
        }

        /* Limitare descriere la 2 rânduri */
        .hotel-description {
            color: #555;
            font-size: 0.95rem;
            margin: 15px 0;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.6;
        }

        /* Facilități (Pills) */
        .perk-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: #f0f4ff;
            color: #0057ff;
            padding: 5px 12px;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-right: 8px;
            margin-bottom: 8px;
            border: 1px solid #d0dfff;
        }

        .price-tag {
            font-size: 1.8rem;
            font-weight: 800;
            color: #d32f2f;
            margin-bottom: 0;
            line-height: 1.2;
        }

        .actions-container {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            align-items: flex-end;
        }

        /* Butoane Acțiuni */
        .btn-edit-outline {
            border: 1px solid #ffc107;
            color: #ffc107;
            background: transparent;
            font-weight: 600;
            padding: 8px 20px;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-edit-outline:hover {
                background: #fff9e6;
                color: #d39e00;
            }

        .btn-delete-red {
            border: 1px solid #dc3545;
            color: #dc3545;
            background: transparent;
            font-weight: 600;
            padding: 8px 20px;
            border-radius: 6px;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-delete-red:hover {
                background: #fff5f5;
                color: #bd2130;
            }
    </style>
}

<div class="results-page-container">
    <!-- PANOU FILTRE (STÂNGA) -->
    <aside style="width: 280px; flex-shrink: 0;">
        <div class="card p-4 border-0 shadow-sm rounded-3">
            <h5 class="fw-bold mb-4">Filtrează după</h5>
            
            <div class="mb-4">
                <label class="fw-bold small mb-2 d-block">Destinație</label>
                @foreach (var oras in Model.Select(h => h.Destinatie?.Oras).Distinct().Where(o => o != null))
                {
                    <div class="form-check">
                        <input class="form-check-input filter-check" type="checkbox" value="@oras" data-type="oras">
                        <label class="form-check-label">@oras</label>
                    </div>
                }
            </div>

            <div class="mb-4">
                <label class="fw-bold small mb-2 d-block">Preț maxim: <span id="priceVal">5000</span> RON</label>
                <input type="range" class="form-range" min="0" max="5000" step="50" id="priceRange" value="5000">
            </div>

            <div class="mb-4">
                <label class="fw-bold small mb-2 d-block">Stele</label>
                @for (int i = 5; i >= 3; i--)
                {
                    <div class="form-check">
                        <input class="form-check-input filter-check" type="checkbox" value="@i" data-type="stele">
                        <label class="form-check-label text-warning">
                            @for (int s = 0; s < i; s++)
                            {
                                <i class="fa-solid fa-star"></i>
                            }
                        </label>
                    </div>
                }
            </div>
            
            <button class="btn btn-primary w-100 fw-bold" onclick="resetFilters()">Resetează tot</button>
        </div>
    </aside>

    <!-- LISTA HOTELURI -->
    <main style="flex-grow: 1;">
        
        <!-- HEADER ADMIN: Număr proprietăți, Căutare și Adăugare -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0" id="resultsCount">Am găsit @Model.Count() proprietăți</h2>

            <div class="d-flex gap-3 align-items-center">
                <!-- Bara de Căutare -->
                <div class="input-group shadow-sm" style="width: 300px; border-radius: 8px; overflow: hidden;">
                    <span class="input-group-text bg-white border-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                    <input type="text" id="searchHoteluri" class="form-control border-0 ps-0" placeholder="Caută hotel...">
                </div>

                <!-- Buton Adaugă (Doar Admin) -->
                @if (esteAdmin)
                {
                    <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm px-4 d-flex align-items-center gap-2">
                        <i class="fa-solid fa-plus"></i> Adaugă Hotel Nou
                    </a>
                }
            </div>
        </div>

        <div id="hotelList">
            @foreach (var item in Model)
            {
                <!-- Am adăugat data-nume pentru căutare -->
                <div class="hotel-card"
                     data-nume="@item.Nume.ToLower()"
                     data-oras="@(item.Destinatie?.Oras ?? "")"
                     data-pret="@item.Pret"
                     data-stele="@item.Stele">
                    
                    <!-- PARTEA STÂNGĂ -->
                    <div class="hotel-visual-box">
                        <h3>@item.Nume</h3>
                        <div class="location-label">
                            <i class="fa-solid fa-location-dot"></i> @(item.Destinatie?.Oras ?? "Locație")
                        </div>
                    </div>

                    <!-- PARTEA DREAPTĂ -->
                    <div class="hotel-details-box">
                        <div class="hotel-title-row">
                            <div>
                                <h3 class="fw-bold mb-0" style="color: #003580;">@item.Nume</h3>
                                <div class="text-warning small mt-1">
                                    @for (int i = 0; i < item.Stele; i++)
                                    {
                                        <i class="fa-solid fa-star"></i>
                                    }
                                </div>
                            </div>
                            <div class="score-badge-container">
                                <div class="score-badge">@item.Rating.ToString("0.0")</div>
                                <div class="small text-muted fw-bold mt-1">Scor</div>
                            </div>
                        </div>

                        <!-- Descriere scurtă -->
                        <div class="hotel-description">
                            @item.Descriere
                        </div>

                        <!-- Facilități -->
                        <div class="mb-auto">
                            @if (item.AreWiFi)
                            {
                                <span class="perk-pill"><i class="fa-solid fa-wifi"></i> Wi-Fi</span>
                            }
                            @if (item.AreMicDejun)
                            {
                                <span class="perk-pill"><i class="fa-solid fa-mug-saucer"></i> Mic Dejun</span>
                            }
                            @if (item.ArePiscina)
                            {
                                <span class="perk-pill"><i class="fa-solid fa-person-swimming"></i> Piscină</span>
                            }
                            @if (item.AreSpa)
                            {
                                <span class="perk-pill"><i class="fa-solid fa-spa"></i> SPA</span>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-end mt-3">
                            <div>
                                <div class="text-success small fw-bold mb-1"><i class="fa-solid fa-check"></i> Anulare gratuită</div>
                                <p class="price-tag">@item.Pret.ToString("N0") RON</p>
                                <div class="text-muted small">pe noapte, 2 adulți</div>
                            </div>
                            
                            <div class="actions-container">
                                @if (esteAdmin)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit-outline">Editează</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete-red">Șterge</a>
                                }
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary px-4 fw-bold">Vezi detalii</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>
</div>

@section Scripts {
    <script>
        const checks = document.querySelectorAll('.filter-check');
        const priceRange = document.getElementById('priceRange');
        const priceVal = document.getElementById('priceVal');
        const searchInput = document.getElementById('searchHoteluri');
        const cards = document.querySelectorAll('.hotel-card');

        function runFilters() {
            let selectedCities = Array.from(document.querySelectorAll('.filter-check[data-type="oras"]:checked')).map(c => c.value);
            let selectedStars = Array.from(document.querySelectorAll('.filter-check[data-type="stele"]:checked')).map(c => c.value);
            let maxP = parseFloat(priceRange.value);
            let searchText = searchInput ? searchInput.value.toLowerCase() : "";
            
            priceVal.innerText = maxP;

            let visibleCount = 0;

            cards.forEach(card => {
                let cardCity = card.getAttribute('data-oras');
                let cardPrice = parseFloat(card.getAttribute('data-pret'));
                let cardStars = card.getAttribute('data-stele');
                let cardName = card.getAttribute('data-nume');
                // Extindem căutarea să includă și destinația, nu doar numele hotelului
                let searchTarget = cardName + " " + cardCity.toLowerCase();

                let cityMatch = selectedCities.length === 0 || selectedCities.includes(cardCity);
                let starMatch = selectedStars.length === 0 || selectedStars.includes(cardStars);
                let priceMatch = cardPrice <= maxP;
                let searchMatch = searchTarget.includes(searchText);

                // Afișează doar dacă respectă TOATE condițiile de filtrare
                if (cityMatch && starMatch && priceMatch && searchMatch) {
                    card.style.display = 'flex';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            document.getElementById('resultsCount').innerText = `Am găsit ${visibleCount} proprietăți`;
        }

        // Atașăm ascultătorii de evenimente
        checks.forEach(c => c.addEventListener('change', runFilters));
        priceRange.addEventListener('input', runFilters);
        if (searchInput) {
            searchInput.addEventListener('keyup', runFilters); // Eveniment pentru bara de căutare
        }

        function resetFilters() {
            checks.forEach(c => c.checked = false);
            priceRange.value = 5000;
            if (searchInput) searchInput.value = "";
            runFilters();
        }

        // ===== LOGICA PENTRU CĂUTAREA DIN PAGINA ACASĂ =====
        document.addEventListener("DOMContentLoaded", function() {
            // Citim parametrul '?search=...' din URL
            const urlParams = new URLSearchParams(window.location.search);
            const searchQuery = urlParams.get('search');

            if (searchQuery && searchInput) {
                // Dacă există o căutare din Home, o punem în bară și declanșăm filtrul
                searchInput.value = searchQuery;
                runFilters();
            }
        });
    </script>
}