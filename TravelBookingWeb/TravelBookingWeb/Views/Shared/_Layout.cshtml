@using System.Security.Claims

<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - TravelBooking</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/general.css">
    <link rel="stylesheet" href="~/css/navbar.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100" style="background-color: #f4f7f6;">

    <nav class="navbar px-4 shadow-sm" style="background-color: #0057ff;">
        <div class="nav-left d-flex align-items-center">
            <div class="logo text-white fs-4 fw-bold me-4">
                <i class="fa-solid fa-plane-departure"></i> TravelBooking
            </div>
            <div class="nav-links d-none d-md-flex align-items-center">
                <a href="/" class="text-white text-decoration-none me-3"><i class="fa-solid fa-house"></i> Acasă</a>
                <a href="/Hotels/Oferte" class="text-white text-decoration-none me-3"><i class="fa-solid fa-hotel"></i> Destinații</a>
                <a href="/Zboruri/Oferte" class="text-white text-decoration-none me-3"><i class="fa-solid fa-plane-up"></i> Zboruri</a>
                <a href="/Inchirieri/Oferte" class="text-white text-decoration-none me-3"><i class="fa-solid fa-car"></i> Închirieri</a>
                <a href="/Activitati/Oferte" class="text-white text-decoration-none me-3"><i class="fa-solid fa-ticket"></i> Activități</a>

                @if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                {
                    <div class="dropdown ms-2">
                        <button class="btn btn-danger btn-sm dropdown-toggle fw-bold" type="button" id="adminMenu" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa-solid fa-lock"></i> Panou Admin
                        </button>
                        <ul class="dropdown-menu shadow" aria-labelledby="adminMenu">
                            <li><a class="dropdown-item fw-bold text-danger" href="/Account/Utilizatori"><i class="fa-solid fa-users me-2"></i> Gestiune Utilizatori</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/Hotels/Index"><i class="fa-solid fa-hotel text-primary me-2"></i> Gestionare Hoteluri</a></li>
                            <li><a class="dropdown-item" href="/Zboruri/Index"><i class="fa-solid fa-plane text-primary me-2"></i> Gestionare Zboruri</a></li>
                            <li><a class="dropdown-item" href="/Activitati/Index"><i class="fa-solid fa-ticket text-primary me-2"></i> Gestionare Activități</a></li>
                        </ul>
                    </div>
                }
            </div>
        </div>

        <div class="nav-right d-flex align-items-center">
            @if (User.Identity.IsAuthenticated)
            {
                // ARHITECTURĂ CURATĂ: Citim datele direct din Cookie (Claims), fără a accesa baza de date!
                var numeUser = User.FindFirst("Prenume")?.Value ?? User.Identity.Name;
                var emailUser = User.FindFirst("Email")?.Value ?? "";
                var imagineProfil = User.FindFirst("ImagineProfil")?.Value;

                @if (!string.IsNullOrEmpty(imagineProfil))
                {
                    <img src="@imagineProfil" class="rounded-circle border border-2 border-white me-2 shadow-sm"
                         style="width: 35px; height: 35px; object-fit: cover;" alt="Profil">
                }
                else
                {
                    var initiala = !string.IsNullOrEmpty(numeUser) && numeUser.Length > 0 ? numeUser.Substring(0, 1).ToUpper() : "?";
                    <div class="rounded-circle bg-white text-primary d-flex justify-content-center align-items-center fw-bold me-2 shadow-sm"
                         style="width: 35px; height: 35px;">
                        @initiala
                    </div>
                }

                <div class="d-flex flex-column me-3 d-none d-md-flex text-start justify-content-center">
                    <span class="text-white" style="line-height: 1.1;">Salut, <strong>@numeUser</strong></span>
                    <small class="text-white-50" style="font-size: 0.75rem;">@emailUser</small>
                </div>

                <a href="/Account/Profil" class="btn btn-outline-light btn-sm me-2">Profil</a>
                <a href="/Account/Logout" class="btn btn-danger btn-sm"><i class="fa-solid fa-right-from-bracket"></i></a>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-outline-light btn-sm me-2">Login</a>
                <a href="/Account/Register" class="btn btn-light text-primary btn-sm fw-bold">Register</a>
            }
        </div>
    </nav>

    <main role="main" class="flex-grow-1 container-fluid py-4">
        @RenderBody()
    </main>

    <footer class="footer mt-auto bg-dark text-white py-4">
        <div class="container text-center">
            <h4 class="mb-3"><i class="fa-solid fa-plane"></i> TravelBooking</h4>
            <div class="mb-3">
                <a href="/Home/Info#despre" class="text-white-50 text-decoration-none mx-2">Despre Noi</a>
                <a href="/Home/Info#termeni" class="text-white-50 text-decoration-none mx-2">Termeni și Condiții</a>
                <a href="/Home/Info#contact" class="text-white-50 text-decoration-none mx-2">Contact</a>
            </div>
            <p class="text-white-50 mb-0 small">&copy; 2026 TravelBooking. Toate drepturile rezervate.</p>
        </div>
    </footer>

    <script src="~/js/main.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>