@model TravelBookingWeb.Models.Zbor
@{
    ViewData["Title"] = "Șterge Zbor";
}

<div class="container mt-4">
    <div class="alert alert-danger">
        <h3>Ești sigur că vrei să ștergi acest zbor?</h3>
    </div>
    <div class="card p-4 shadow-sm">
        <dl class="row">
            <dt class="col-sm-3">Companie:</dt>
            <dd class="col-sm-9"><strong>@Model.CompanieAeriana</strong></dd>
            <dt class="col-sm-3">Ruta / Escale:</dt>
            <dd class="col-sm-9">@Model.Escale (@Model.Durata)</dd>
            <dt class="col-sm-3">Preț:</dt>
            <dd class="col-sm-9">@Model.Pret RON</dd>
        </dl>
        
        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Confirmă Ștergerea" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary ms-2">Anulează</a>
        </form>
    </div>
</div>