@model TravelBookingWeb.Models.Rezervare
@{
    ViewData["Title"] = "Modifică Rezervarea";
}

<div class="container mt-5 mb-5">
    <div class="card border-0 shadow-sm rounded-3 mx-auto" style="max-width: 600px;">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0"><i class="fa-solid fa-pen-to-square me-2"></i> Modificare Detalii Rezervare</h4>
        </div>
        <div class="card-body p-4">
            
            <div class="alert alert-info border-0 shadow-sm mb-4">
                <i class="fa-solid fa-circle-info me-2"></i> <strong>Atenție:</strong> Modificarea datelor de călătorie poate duce la recalcularea prețului. În sezon (Iulie-August) se aplică tarife de vârf (+30%).
            </div>

            <form asp-action="EditeazaRezervare" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Data Check-in</label>
                        <input type="date" name="DataInceput" class="form-control" value="@Model.DataInceput.ToString("yyyy-MM-dd")" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Data Check-out</label>
                        <input type="date" name="DataSfarsit" class="form-control" value="@Model.DataSfarsit.ToString("yyyy-MM-dd")" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Facilități dorite</label>
                    <select name="Facilitati" class="form-select">
                        <option value="Standard" selected="@(Model.Facilitati == "Standard")">Standard (Doar cazare/zbor)</option>
                        <option value="Premium (Spa, Mic dejun, Parcare)" selected="@(Model.Facilitati == "Premium (Spa, Mic dejun, Parcare)")">Premium (Spa, Mic dejun, Parcare) - Extra Cost</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Metoda de Plată</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="MetodaPlata" value="Card" id="plataCard" @(Model.MetodaPlata == "Card" ? "checked" : "")>
                        <label class="form-check-label" for="plataCard"><i class="fa-brands fa-cc-visa text-primary me-1"></i> Card Bancar Online (Achitat instant)</label>
                    </div>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="radio" name="MetodaPlata" value="Numerar" id="plataNumerar" @(Model.MetodaPlata == "Numerar" ? "checked" : "")>
                        <label class="form-check-label" for="plataNumerar"><i class="fa-solid fa-money-bill-wave text-success me-1"></i> Numerar la locație (Neachitat)</label>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center border-top pt-3 mt-4">
                    <a href="/Account/Rezervari" class="btn btn-outline-secondary fw-bold">Înapoi</a>
                    <button type="submit" class="btn btn-primary fw-bold px-4">Recalculează & Salvează</button>
                </div>
            </form>
        </div>
    </div>
</div>