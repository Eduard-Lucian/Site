@model TravelBookingWeb.Models.ApplicationUser
@{
    ViewData["Title"] = "Editează Client";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fa-solid fa-user-pen"></i> Editează Date Client</h4>
                </div>
                <div class="card-body">
                    <form method="post" action="/Account/EditeazaUtilizator">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label class="form-label">Nume</label>
                            <input asp-for="Nume" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Prenume</label>
                            <input asp-for="Prenume" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Telefon</label>
                            <input asp-for="PhoneNumber" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Adresă</label>
                            <input asp-for="Adresa" class="form-control" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/Account/Utilizatori" class="btn btn-secondary">Înapoi</a>
                            <button type="submit" class="btn btn-success">Salvează Modificările</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>