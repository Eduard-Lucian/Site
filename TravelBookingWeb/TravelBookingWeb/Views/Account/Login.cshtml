@{
    // Dezactivăm layout-ul general pentru ca pagina să aibă propriul fundal pe tot ecranul
    Layout = null;
}
<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Autentificare - TravelBooking</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/general.css">
    <link rel="stylesheet" href="~/css/auth.css">
</head>
<body class="auth-body">

    <div class="auth-card">
        <div class="auth-logo">
            <i class="fa-solid fa-plane"></i> TravelBooking
        </div>
        <p class="auth-subtitle">Bine ai revenit! Autentifică-te pentru a continua.</p>

        <form class="auth-form" asp-controller="Account" asp-action="Login" method="post">

            @if (ViewBag.Eroare != null)
            {
                <div class="alert alert-danger" style="color: red; margin-bottom: 15px; font-size: 0.9em; text-align: left; background: #ffe6e6; padding: 10px; border-radius: 5px;">
                    <i class="fa-solid fa-triangle-exclamation"></i> @ViewBag.Eroare
                </div>
            }

            <label>Adresa de Email</label>
            <input type="email" name="email" value="@ViewBag.PrefillEmail" placeholder="ion.popescu@gmail.com" required>

            <label>Parola</label>
            <input type="password" name="parola" value="@ViewBag.PrefillPassword" placeholder="Introdu parola" required>

            <button type="submit" class="btn-auth">Intră în cont</button>
        </form>

        <div class="auth-links">
            Nu ai un cont? <a href="/Account/Register">Înregistrează-te aici</a>
        </div>
        <div class="auth-links" style="margin-top: 10px;">
            <a href="/" style="color: #666; font-weight: normal;"><i class="fa-solid fa-arrow-left"></i> Înapoi pe site (Vizitator)</a>
        </div>
    </div>

</body>
</html>