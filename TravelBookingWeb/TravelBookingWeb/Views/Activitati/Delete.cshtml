@model TravelBookingWeb.Models.Activitate
@{
    ViewData["Title"] = "Șterge Activitate";
}

<div class="container mt-4">
    <div class="alert alert-danger">
        <h3>Ești sigur că vrei să ștergi această activitate?</h3>
    </div>
    <div class="card p-4 shadow-sm">
        <dl class="row">
            <dt class="col-sm-3">Nume:</dt>
            <dd class="col-sm-9"><strong>@Model.Nume_Activitate</strong></dd>
            <dt class="col-sm-3">Categorie / Durată:</dt>
            <dd class="col-sm-9">@Model.Categorie (@Model.Durata)</dd>
            <dt class="col-sm-3">Preț:</dt>
            <dd class="col-sm-9">@Model.Pret_pe_persoana RON</dd>
        </dl>
        
        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Confirmă Ștergerea" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary ms-2">Anulează</a>
        </form>
    </div>
</div>