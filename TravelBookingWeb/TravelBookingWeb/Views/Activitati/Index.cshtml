@model IEnumerable<TravelBookingWeb.Models.Activitate>
@{
    ViewData["Title"] = "Administrare Activități";
}

<div class="container-fluid px-md-5 mt-4">
    <!-- Header Page -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold"><i class="fa-solid fa-ticket text-primary"></i> Administrare Activități</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm fw-bold">
            <i class="fa-solid fa-plus me-1"></i> Adaugă Activitate Nouă
        </a>
    </div>

    <!-- Card Wrapper -->
    <div class="card border-0 shadow-sm rounded-3">
        <!-- Search Bar -->
        <div class="card-header bg-white border-bottom-0 py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-muted"><i class="fa-solid fa-list me-2"></i>Lista Activităților</h5>
            <div class="input-group" style="max-width: 300px;">
                <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-magnifying-glass"></i></span>
                <input type="text" id="searchActivitati" class="form-control border-start-0 bg-light" placeholder="Caută activitate...">
            </div>
        </div>

        <!-- Tabel Responsiv -->
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="activitatiTable">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4">Nume Activitate</th>
                            <th>Categorie</th>
                            <th>Durată</th>
                            <th>Preț / Pers.</th>
                            <th>Destinație</th>
                            <th class="text-end pe-4">Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@item.Nume_Activitate</td>
                                <td><span class="badge bg-info text-dark rounded-pill">@item.Categorie</span></td>
                                <td><i class="fa-regular fa-clock text-muted"></i> @item.Durata</td>
                                <td><span class="text-success fw-bold">@item.Pret_pe_persoana RON</span></td>
                                <td class="text-muted">
                                    <i class="fa-solid fa-location-dot me-1 text-danger"></i>
                                    @(item.Destinatie != null ? item.Destinatie.Oras + ", " + item.Destinatie.Tara : "Nespecificat")
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning fw-bold me-2">
                                        <i class="fa-solid fa-pen-to-square"></i> Editează
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger fw-bold">
                                        <i class="fa-solid fa-trash"></i> Șterge
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchActivitati').addEventListener('keyup', function() {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll('#activitatiTable tbody tr');
            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            });
        });
    </script>
}