@model TravelBookingWeb.ViewModels.ActivitateViewModel

@{
    ViewData["Title"] = "Adaugă Activitate";
}

<div class="container mt-5 mb-5">
    <div class="card shadow-sm border-0 rounded-3 p-4" style="background-color: #f8f9fa;">
        <h2 class="mb-4 text-primary">Adaugă Activitate Nouă</h2>
        <hr />

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Nume Activitate</label>
                <input type="text" asp-for="Nume_Activitate" class="form-control" required>
                <span asp-validation-for="Nume_Activitate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Categorie</label>
                <input type="text" asp-for="Categorie" id="categorieInput" class="form-control" list="listaCategorii" placeholder="Selectează o categorie pentru a genera imaginea..." required autocomplete="off">
                <datalist id="listaCategorii">
                    <option value="Tururi"></option>
                    <option value="Muzee"></option>
                    <option value="Gastronomie"></option>
                    <option value="Festivaluri/Turnee"></option>
                    <option value="Parcuri de distracții"></option>
                </datalist>
                <span asp-validation-for="Categorie" class="text-danger"></span>
            </div>

            <input type="hidden" asp-for="Imagine" id="imagineInput" required>

            <div class="mb-4" id="previewContainer" style="display: none;">
                <label class="form-label fw-bold text-success"><i class="fa-solid fa-image"></i> Imagine generată automat:</label>
                <div class="text-center bg-white p-2 rounded shadow-sm border">
                    <img id="imaginePreview" src="" alt="Preview" class="img-fluid rounded" style="max-height: 250px; width: 100%; object-fit: cover;" />
                    <button type="button" id="btnRefreshImage" class="btn btn-sm btn-outline-secondary mt-2 w-100 fw-bold">
                        <i class="fa-solid fa-arrow-right"></i> Următoarea imagine
                    </button>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Durata</label>
                <input type="text" asp-for="Durata" class="form-control" placeholder="Ex: 3-5 ore" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Preț per persoană (RON)</label>
                <input type="number" asp-for="Pret_pe_persoana" class="form-control" step="0.01" required>
                <span asp-validation-for="Pret_pe_persoana" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Destinație</label>
                <select asp-for="DestinatieId" asp-items="@Model.DestinatiiDisponibile" class="form-select" required>
                    <option value="">-- Selectează o destinație din baza de date --</option>
                </select>
                <span asp-validation-for="DestinatieId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-success fw-bold px-4">Salvează Activitatea</button>
                <a asp-action="Index" class="btn btn-secondary">Anulează</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener("DOMContentLoaded", function() {

            const galerieImagini = {
                "Tururi": [
                    "https://images.unsplash.com/photo-1499856871958-5b9627545d1a?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1552832230-c0197dd311b5?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1506973035872-a4ec16b8e8d9?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1502602898657-3e91760cbb34?w=1000&auto=format&fit=crop"
                ],
                "Muzee": [
                    "https://images.unsplash.com/photo-1518998053401-b413cbdf39c1?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1580537659466-0a9bfa916a54?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1566127444979-b3d2b654e3d7?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1533105079780-92b9be482077?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1544928147-79a2dbc1f389?w=1000&auto=format&fit=crop"
                ],
                "Gastronomie": [
                    "https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1550966871-3ed3cdb5ed0c?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1476224203421-9ce810816f69?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1559339352-11d035aa65de?w=1000&auto=format&fit=crop"
                ],
                "Festivaluri/Turnee": [
                    "https://images.unsplash.com/photo-1459749411175-04bf5292ceea?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1470229722913-7c092bb4ace4?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1514525253161-7a46d19cd819?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1533174000255-824b07fb7717?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1540039155733-5b4cdd88df0a?w=1000&auto=format&fit=crop"
                ],
                "Parcuri de distracții": [
                    "https://images.unsplash.com/photo-1513889961551-628c1e5e2ee9?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1505993597083-3ae91b6654b4?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1579308696803-b0978ee8cc8a?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1600861194942-f76f7b94b0d4?w=1000&auto=format&fit=crop",
                    "https://images.unsplash.com/photo-1528605248644-14dd04022da1?w=1000&auto=format&fit=crop"
                ]
            };

            const indexCurent = {
                "Tururi": 0, "Muzee": 0, "Gastronomie": 0, "Festivaluri/Turnee": 0, "Parcuri de distracții": 0
            };

            const catIn = document.getElementById('categorieInput');
            const imgIn = document.getElementById('imagineInput');
            const imgPre = document.getElementById('imaginePreview');
            const previewContainer = document.getElementById('previewContainer');
            const btnRefresh = document.getElementById('btnRefreshImage');

            function seteazaImaginea(categorie, treceLaUrmatoarea) {
                const listaImagini = galerieImagini[categorie];

                if(listaImagini && listaImagini.length > 0) {
                    if(treceLaUrmatoarea) {
                        indexCurent[categorie] = (indexCurent[categorie] + 1) % listaImagini.length;
                    }

                    const imagineNoua = listaImagini[indexCurent[categorie]];

                    imgIn.value = imagineNoua;
                    imgPre.style.opacity = 0;
                    imgPre.src = imagineNoua;
                    setTimeout(() => { imgPre.style.opacity = 1; imgPre.style.transition = "opacity 0.3s ease-in"; }, 150);

                    previewContainer.style.display = "block";
                } else {
                    previewContainer.style.display = "none";
                    imgIn.value = "";
                }
            }

            catIn.addEventListener('change', function() {
                seteazaImaginea(this.value, false);
            });

            btnRefresh.addEventListener('click', function(e) {
                e.preventDefault();
                seteazaImaginea(catIn.value, true);
            });

            function setupAutoShow(id) {
                const el = document.getElementById(id);
                if (!el) return;
                let backup = "";
                el.addEventListener('focus', function() { backup = this.value; this.value = ''; });
                el.addEventListener('blur', function() { if(!this.value) this.value = backup; });
            }

            setupAutoShow('categorieInput');
        });
    </script>
}